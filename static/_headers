# Cloudflare Pages static asset cache headers.
# Compiled JS/CSS bundles get content-hash filenames — safe to cache forever.
# Fonts and icons are stable — also cache forever.

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=31536000, immutable

/manifest.webmanifest
  Cache-Control: public, max-age=3600

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable
